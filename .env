# Google OAuth Client ID for Drive backup feature.
# Steps:
#  1. Go to https://console.cloud.google.com/
#  2. Create a project → Enable "Google Drive API"
#  3. OAuth consent screen → External → add your domain
#  4. Credentials → Create OAuth 2.0 Client ID → Web application
#  5. Add your domain to "Authorized JavaScript origins"
#     e.g. http://localhost:5173 for dev, https://yourdomain.com for prod
#  6. Copy the Client ID below

VITE_GOOGLE_CLIENT_ID=684192360235-b0e1uldde3si33ehmlg08a8q2pjm63e2.apps.googleusercontent.com
